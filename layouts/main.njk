{% extends "./base.njk" %}

{% block content %}
  <header class="sticky top-0 z-50 bg-white">
    <section aria-label="Utility bar" class="bg-blue-600 text-white text-xs">
      <div class="wrapper flex justify-between items-center py-1.5">
        <div class="flex gap-4">
          <span class="*:align-middle">
            <i data-lucide="map-pin"></i>
            Kirim ke: Jakarta Selatan
          </span>
        </div>
        <div class="flex gap-4">
          <span class="*:align-middle">
            📞
            <a href="tel:0800-1234-5678">0800&#8209;1234&#8209;5678</a>
            (Gratis)
          </span>
          <span class="*:align-middle">
            🚀 Gratis ongkir di atas Rp 100.000
          </span>
        </div>
      </div>
    </section>

    <section aria-label="Main header" class="py-2 shadow-sm">
      <div class="wrapper flex gap-4 items-center">
        <a class="brand" href="index.html">BeliMudah</a>

        <form
          class="flex items-center gap-2 h-10 border border-black/10 rounded-xl bg-gray-100 overflow-hidden focus-within:border-black/50 transition-colors duration-200 *:px-4 *:h-full *:transition-colors *:duration-200"
        >
          <input
            class="flex-1 min-w-[32rem] text-sm bg-transparent focus:outline-none"
            type="text"
            name="q"
            autocomplete="off"
            placeholder="Cari produk, merek, kategori..."
          />
          <button
            class="shrink-0 text-white bg-blue-600 hover:bg-blue-700 focus:bg-blue-900 focus:outline-none"
            type="submit"
            aria-label="Search"
          >
            <i data-lucide="search" class="text-base"></i>
          </button>
        </form>

        <div
          class="flex items-center mx-2 gap-6 text-xl **:transition-colors **:duration-200 *:flex *:items-center *:gap-2"
        >
          <a class="group" aria-label="Notifications" href="">
            <i
              data-lucide="bell"
              class="text-gray-500 group-hover:text-black"
            ></i>
          </a>
          <a class="group" aria-label="User" href="">
            <i
              data-lucide="user"
              class="text-gray-500 group-hover:text-black"
            ></i>
            <span class="text-sm">Budi</span>
          </a>
          <a class="group" aria-label="Favorite" href="">
            <i
              data-lucide="heart"
              class="text-gray-500 group-hover:text-black"
            ></i>
          </a>
          <a class="group" aria-label="Cart" href="">
            <i
              data-lucide="shopping-cart"
              class="text-gray-500 group-hover:text-black"
            ></i>
          </a>
        </div>
      </div>
    </section>

    <nav aria-label="Main navigations" class="py-2.5 text-sm shadow-sm">
      <div
        class="wrapper flex *:px-4 *:whitespace-nowrap *:transition-colors *:duration-200"
      >
        <a class="flex items-center gap-1 text-black" href="">
          <i data-lucide="menu"></i>
          Semua Kategori
          <i data-lucide="chevron-down"></i>
        </a>
        <!--  -->
      </div>
    </nav>
  </header>

  {% block main %}{% endblock %}

  <footer
    class="bg-gray-900 text-gray-400 text-sm [&_a]:transition-colors [&_a]:hover:text-white"
  >
    <a
      class="fixed bottom-4 end-4 grid place-content-center w-14 h-14 text-2xl rounded-full bg-blue-600 text-white shadow-md"
      aria-label="Contact us"
      href=""
    >
      <i data-lucide="message-circle"></i>
    </a>

    <section aria-label="Promotions" class="py-8">
      <div class="wrapper grid grid-cols-4 gap-8">
        <div class="flex gap-4">
          <div
            class="grid place-content-center shrink-0 size-10 rounded-full bg-blue-600/20 text-blue-600"
          >
            <i class="text-lg" data-lucide="truck"></i>
          </div>
          <div class="flex flex-col justify-center">
            <h6 class="text-white text-sm font-medium">Gratis Ongkir</h6>
            <span class="text-xs">Pembelian diatas Rp 100.000</span>
          </div>
        </div>
        <div class="flex gap-4">
          <div
            class="grid place-content-center shrink-0 size-10 rounded-full bg-blue-600/20 text-blue-600"
          >
            <i class="text-lg" data-lucide="shield"></i>
          </div>
          <div class="flex flex-col justify-center">
            <h6 class="text-white text-sm font-medium">Pembayaran Aman</h6>
            <span class="text-xs">SSL terenkripsi 256-bit</span>
          </div>
        </div>
        <div class="flex gap-4">
          <div
            class="grid place-content-center shrink-0 size-10 rounded-full bg-blue-600/20 text-blue-600"
          >
            <i class="text-lg" data-lucide="refresh-ccw"></i>
          </div>
          <div class="flex flex-col justify-center">
            <h6 class="text-white text-sm font-medium">Pengembalian Mudah</h6>
            <span class="text-xs">30 hari pengembalian gratis</span>
          </div>
        </div>
        <div class="flex gap-4">
          <div
            class="grid place-content-center shrink-0 size-10 rounded-full bg-blue-600/20 text-blue-600"
          >
            <i class="text-lg" data-lucide="headset"></i>
          </div>
          <div class="flex flex-col justify-center">
            <h6 class="text-white text-sm font-medium">Dukungan 24/7</h6>
            <span class="text-xs">Bantuan kapan saja</span>
          </div>
        </div>
      </div>
    </section>

    <hr class="border-gray-700" />

    <nav aria-label="Main footer" class="py-8">
      <div class="wrapper grid grid-cols-4 gap-8">
        <div class="flex flex-col gap-4">
          <a class="brand text-white text-lg" href="">BeliMudah</a>
          <p class="text-gray-400 leading-relaxed">
            Platform belanja online terpercaya dengan ribuan produk pilihan.
            Belanja mudah, aman, dan menyenangkan.
          </p>
          <div
            class="flex gap-2 *:grid *:place-content-center *:size-8 *:rounded-full *:overflow-hidden *:bg-gray-700"
          >
            <a aria-label="Facebook" href=""><i class="si si-facebook"></i></a>
            <a aria-label="Instagram" href=""
              ><i class="si si-instagram"></i
            ></a>
            <a aria-label="X" href=""><i class="si si-x"></i></a>
            <a aria-label="YouTube" href=""><i class="si si-youtube"></i></a>
          </div>
        </div>

        <div class="flex flex-col gap-4">
          <h5 class="text-white text-base font-medium">Layanan</h5>
          <ul class="flex flex-col gap-4 list-none">
            <li><a href="">Tentang Kami</a></li>
            <li><a href="">Karir</a></li>
            <li><a href="">Blog</a></li>
            <li><a href="">Program Afiliasi</a></li>
            <li><a href="">Jual di BeliMudah</a></li>
          </ul>
        </div>

        <div class="flex flex-col gap-4">
          <h5 class="text-white text-base font-medium">Bantuan</h5>
          <ul class="flex flex-col gap-4 list-none">
            <li><a href="">Cara Belanja</a></li>
            <li><a href="">Kebijakan Pengembalian</a></li>
            <li><a href="">Lacak Pesanan</a></li>
            <li><a href="">FAQ</a></li>
            <li><a href="">Hubungi Kami</a></li>
          </ul>
        </div>

        <div class="flex flex-col gap-4">
          <h5 class="text-white text-base font-medium">Kontak</h5>
          <ul
            class="flex flex-col gap-4 list-none *:ps-6 *:relative [&_svg.lucide]:absolute [&_svg.lucide]:left-0 [&_svg.lucide]:text-base"
          >
            <li>
              <a href="">
                <i data-lucide="map-pin"></i>
                Jl. Sudirman No. 1, Jakarta Selatan, DKI Jakarta 12190
              </a>
            </li>
            <li>
              <a href="tel:0800-1234-5678">
                <i data-lucide="phone"></i>
                0800&#8209;1234&#8209;5678&nbsp;(Gratis)
              </a>
            </li>
            <li>
              <a href="mailto:bantuan@belimudah.id">
                <i data-lucide="mail"></i>
                bantuan@belimudah.id
              </a>
            </li>
          </ul>
          <div class="bg-gray-800 border border-white/10 rounded-lg text-xs">
            <form class="p-3 flex flex-col gap-2">
              <label class="text-white font-medium" for="newsletter"
                >Newsletter</label
              >
              <div class="flex gap-2">
                <input
                  class="w-full flex-1 px-3 py-2.5 rounded-md bg-gray-700 border border-white/10"
                  id="newsletter"
                  name="newsletter"
                  type="email"
                  placeholder="Email kamu"
                />
                <button
                  class="px-3 py-2.5 rounded-md bg-blue-600 text-white cursor-pointer"
                  type="submit"
                >
                  Langganan
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </nav>

    <hr class="border-gray-700" />

    <section aria-label="Copyright" class="py-4 text-xs text-gray-500">
      <div class="wrapper flex justify-between">
        <small>&copy; 2026 BeliMudah. Seluruh hak cipta dilindungi.</small>
        <small class="flex gap-4">
          <a href="">Kebijakan Privasi</a>
          <a href="">Syarat &amp; Ketentuan</a>
          <a href="">Admin</a>
        </small>
      </div>
    </section>
  </footer>

  {% block script %}{% endblock %}
{% endblock %}
