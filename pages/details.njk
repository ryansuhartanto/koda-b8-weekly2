{% extends "../layouts/main.njk" %}

{% block main %}
  <main class="pt-6 pb-16 bg-gray-50">
    <div class="wrapper flex flex-col gap-10">
      <nav
        aria-label="Breadcrumb"
        class="flex items-center gap-1 text-sm text-gray-400 [&_a]:transition-colors [&_a]:hover:text-black [&_span]:text-black"
      >
        <a href="#">Beranda</a>
        <i data-lucide="chevron-right" class="size-4"></i>
        <a href="#">Toko</a>
        <i data-lucide="chevron-right" class="size-4"></i>
        <a href="#">Elektronik</a>
        <i data-lucide="chevron-right" class="size-4"></i>
        <span>Headphone Wireless Premium</span>
      </nav>
      <section class="grid grid-cols-2 gap-12 items-start">
        <div class="flex flex-col gap-4">
          <div
            class="relative bg-white border border-black/10 rounded-2xl overflow-hidden aspect-square"
          >
            <span
              class="absolute top-4 left-4 bg-red-600 text-white text-xs px-2.5 py-1 rounded-full font-medium"
              >-31%</span
            >
            <img
              src="images/product/soundwave-headphone_wireless_premium.png"
              alt="Headphone Wireless Premium"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="flex gap-4">
            <button
              type="button"
              class="size-20 border-2 border-blue-600 rounded-xl overflow-hidden cursor-pointer shrink-0"
            >
              <img
                src="images/product/soundwave-headphone_wireless_premium.png"
                alt="Thumbnail 1"
                class="w-full h-full object-cover"
              />
            </button>
            <button
              type="button"
              class="size-20 border border-black/10 rounded-xl overflow-hidden cursor-pointer opacity-70 hover:opacity-100 transition-opacity shrink-0"
            >
              <img
                src="images/product/soundwave-headphone_wireless_premium_2.png"
                alt="Thumbnail 1"
                class="w-full h-full object-cover"
              />
            </button>
          </div>
        </div>
        <div class="flex flex-col gap-5">
          <div class="flex flex-col gap-1">
            <div class="text-sm text-gray-500">SoundWave &bull; Audio</div>
            <h1 class="text-3xl font-bold text-gray-900">
              Headphone Wireless Premium
            </h1>
            <div class="flex items-center gap-4 text-sm">
              <div
                class="flex items-center gap-1 tabular-nums text-amber-400"
                id="pdp-rating"
              >
                <span class="ml-1 text-gray-900">4.8</span>
                <span class="text-gray-500">(512)</span>
              </div>
              <div
                class="flex items-center gap-1 p-0.5 px-2 rounded-full text-xs text-green-600 bg-green-50"
              >
                <i data-lucide="check"></i>
                Stok tersedia (45)
              </div>
            </div>
          </div>
          <div class="flex flex-col gap-1 p-4 rounded-xl bg-blue-50">
            <div class="flex items-center gap-3">
              <ins class="text-3xl font-bold text-blue-600">Rp 450.000</ins>
              <del class="text-gray-500 text-lg">Rp 650.000</del>
              <span
                class="bg-red-600 text-white text-xs font-medium p-0.5 px-2 rounded-full"
                >Hemat 31%</span
              >
            </div>
            <span class="text-green-600 text-sm font-medium"
              >Kamu hemat Rp 200.000</span
            >
          </div>
          <div class="flex flex-col gap-2">
            <div class="text-sm text-gray-500">
              Warna: <span class="text-blue-600">Hitam</span>
            </div>
            <div class="flex gap-2">
              <button
                type="button"
                class="p-1.5 px-3 text-sm border border-blue-600 bg-blue-50 text-blue-600 rounded-lg cursor-pointer font-medium"
              >
                Hitam
              </button>
              <button
                type="button"
                class="p-1.5 px-3 text-sm border border-gray-200 text-gray-600 hover:border-gray-300 rounded-lg cursor-pointer bg-white"
              >
                Putih
              </button>
              <button
                type="button"
                class="p-1.5 px-3 text-sm border border-gray-200 text-gray-600 hover:border-gray-300 rounded-lg cursor-pointer bg-white"
              >
                Biru
              </button>
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <span class="text-sm text-gray-900">Jumlah</span>
            <div class="flex items-center gap-4">
              <div
                class="flex items-center border border-gray-300 rounded-lg overflow-hidden h-10 w-32 bg-white"
              >
                <button
                  type="button"
                  class="w-10 h-full flex items-center justify-center text-gray-500 hover:bg-gray-50 cursor-pointer"
                  onclick="this.nextElementSibling.stepDown()"
                >
                  &minus;
                </button>
                <input
                  type="number"
                  value="1"
                  min="1"
                  class="flex-1 w-full text-center text-sm font-medium outline-none bg-transparent [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
                />
                <button
                  type="button"
                  class="w-10 h-full flex items-center justify-center text-gray-500 hover:bg-gray-50 cursor-pointer"
                  onclick="this.previousElementSibling.stepUp()"
                >
                  &plus;
                </button>
              </div>
              <span class="text-sm text-gray-500">Stok: 45 pcs</span>
            </div>
          </div>
          <div class="flex gap-4 mb-8">
            <button
              type="button"
              class="flex-1 flex items-center justify-center gap-2 border-2 border-orange-500 text-orange-500 font-medium bg-orange-50/50 py-3 rounded-xl hover:bg-orange-50 transition-colors cursor-pointer"
            >
              <i data-lucide="shopping-cart" class="size-5"></i>
              Tambah ke Keranjang
            </button>
            <button
              type="button"
              class="flex-1 bg-orange-500 text-white font-medium py-3 rounded-xl hover:bg-orange-600 transition-colors cursor-pointer shadow-sm shadow-orange-500/20"
            >
              Beli Sekarang
            </button>
            <button
              type="button"
              class="w-14 flex items-center justify-center border border-gray-300 text-gray-500 bg-white rounded-xl hover:bg-gray-50 transition-colors cursor-pointer"
            >
              <i data-lucide="heart" class="size-5"></i>
            </button>
          </div>
          <div class="grid grid-cols-3 gap-4">
            <div
              class="bg-gray-100 rounded-xl p-4 flex flex-col items-center justify-center text-center gap-2"
            >
              <i data-lucide="truck" class="text-blue-600 size-5"></i>
              <div>
                <div class="text-xs font-medium text-gray-900">
                  Gratis Ongkir
                </div>
                <div class="text-[10px] text-gray-500 mt-0.5">
                  Min. Rp 100.000
                </div>
              </div>
            </div>
            <div
              class="bg-gray-100 rounded-xl p-4 flex flex-col items-center justify-center text-center gap-2"
            >
              <i data-lucide="shield-check" class="text-blue-600 size-5"></i>
              <div>
                <div class="text-xs font-medium text-gray-900">
                  Pembayaran Aman
                </div>
                <div class="text-[10px] text-gray-500 mt-0.5">
                  SSL Terenkripsi
                </div>
              </div>
            </div>
            <div
              class="bg-gray-100 rounded-xl p-4 flex flex-col items-center justify-center text-center gap-2"
            >
              <i data-lucide="refresh-ccw" class="text-blue-600 size-5"></i>
              <div>
                <div class="text-xs font-medium text-gray-900">
                  Retur 30 Hari
                </div>
                <div class="text-[10px] text-gray-500 mt-0.5">Gratis retur</div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="border border-black/10 rounded-2xl overflow-hidden mt-4">
        <div class="flex border-b border-black/10 bg-white">
          <button
            type="button"
            class="p-4 text-sm font-medium text-blue-600 border-b-2 border-blue-600 cursor-pointer"
          >
            Deskripsi
          </button>
          <button
            type="button"
            class="p-4 text-sm text-gray-500 hover:text-gray-900 cursor-pointer"
          >
            Spesifikasi
          </button>
          <button
            type="button"
            class="p-4 text-sm text-gray-500 hover:text-gray-900 cursor-pointer"
          >
            Ulasan (2)
          </button>
        </div>
        <div class="p-6 bg-white text-gray-600 leading-relaxed">
          Headphone wireless dengan teknologi noise-cancelling terdepan. Nikmati
          musik favoritmu tanpa gangguan dengan kualitas suara yang memukau.
        </div>
      </section>
      <section class="flex flex-col gap-6">
        <h2 class="text-xl font-semibold">Produk Terkait</h2>
        <div id="related-grid" class="grid grid-cols-4 gap-4"></div>
      </section>
    </div>
  </main>
{% endblock %}

{% block script %}
  <script type="module">
    import $ from "jquery";
    import { createIcons, icons } from "lucide";

    import { ProductCard } from "./scripts/product-card.js";

    import data from "./data.json" with { type: "json" };

    await $.ready;

    $("[aria-label='Main navigations']>div").append(
      ...data.categories.map(({ name, icon }) =>
        $("<a>", {
          class: "text-gray-500 hover:text-black",
          href: "",
          text: `${icon} ${name}`,
        }),
      ),
      $("<a>", {
        class: "text-red-600 hover:text-red-900",
        href: "",
        text: `🔥 Promo`,
      }),
    );

    const pdpStars = Array.from({ length: 5 }, (_, i) =>
      $("<i>", {
        "data-lucide": "star",
        fill: "currentColor",
        "stroke-width": "0",
        class: "size-4",
      }),
    );
    $("#pdp-rating").prepend(...pdpStars);

    const relatedNames = [
      "Smartphone 5G Ultra",
      "Smartwatch Series 5",
      'Tablet 10.5" WiFi + 4G',
      "Speaker Bluetooth Portable",
    ];

    const relatedProducts = relatedNames
      .map((name) => data.products.find((p) => p.name === name))
      .filter(Boolean);

    $("#related-grid").append(...relatedProducts.map(ProductCard));

    createIcons({ icons });
  </script>
{% endblock %}
