{% extends "../layouts/main.njk" %}
{% from "../components/checkout.njk" import stepper, summary %}

{% block main %}
  <main class="pt-6 pb-16 bg-gray-50">
    <div class="wrapper flex flex-col gap-12">
      {{ stepper(3) }}

      <div class="grid grid-cols-3 gap-8 items-start">
        <section
          aria-label="Order confirmation"
          class="col-span-2 flex flex-col gap-6 bg-white border border-black/10 rounded-2xl p-6"
        >
          <h2 class="text-lg font-medium text-gray-900">Konfirmasi Pesanan</h2>

          <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-4">
              <div class="flex flex-col gap-1 p-4 bg-gray-50 rounded-xl">
                <h3 class="text-sm font-medium text-gray-900">
                  Alamat Pengiriman
                </h3>
                <p class="text-sm text-gray-600">
                  Budi Santoso &bull; 0812-3456-7890
                </p>
                <p class="text-sm text-gray-600">
                  Jl. Kebon Jeruk No. 15, Jakarta Barat, DKI Jakarta 11530
                </p>
              </div>

              <div class="flex flex-col gap-1 p-4 bg-gray-50 rounded-xl">
                <h3 class="text-sm font-medium text-gray-900">
                  Metode Pengiriman
                </h3>
                <p class="text-sm text-gray-600">
                  JNE Reguler &bull; 3-5 hari kerja
                </p>
              </div>

              <div class="flex flex-col gap-4 p-4 bg-gray-50 rounded-xl">
                <h3 class="text-sm font-medium text-gray-900">
                  Produk yang Dipesan
                </h3>
                <div id="order-review-items" class="flex flex-col gap-3"></div>
              </div>
            </div>

            <div
              class="flex gap-3 items-center p-4 rounded-xl bg-blue-50 text-blue-700 text-xs"
            >
              <i data-lucide="shield-check" class="size-5 shrink-0"></i>
              <p>
                Dengan menekan 'Bayar Sekarang', kamu menyetujui Syarat &
                Ketentuan kami. Pembayaran baru akan diproses setelah kamu
                mengkonfirmasi di langkah ini.
              </p>
            </div>

            <div class="flex gap-4">
              <button
                type="button"
                class="px-6 py-3 border border-black/10 rounded-xl text-gray-600 font-medium hover:bg-gray-50 transition-colors cursor-pointer shrink-0"
              >
                Kembali
              </button>
              <button
                type="button"
                class="flex-1 flex items-center justify-center gap-2 bg-orange-500 text-white py-3 rounded-xl hover:bg-orange-600 font-medium cursor-pointer shadow-sm shadow-orange-500/20 transition-colors"
              >
                🔒 Bayar <span id="btn-pay-total">Rp 0</span> Sekarang
              </button>
            </div>
          </div>
        </section>

        {{ summary() }}
      </div>
    </div>
  </main>
{% endblock %}

{% block script %}
  <script type="module">
    import $ from "jquery";
    import { createIcons, icons } from "lucide";
    import { SummaryItem, OrderReviewItem } from "./scripts/components.js";
    import data from "./data.json" with { type: "json" };

    await $.ready;

    const cartItem = { ...data.products[0], quantity: 1 };
    const formattedTotal = `Rp ${(cartItem.price * cartItem.quantity).toLocaleString("id-ID")}`;

    $("#summary-items").append(SummaryItem(cartItem));
    $("#order-review-items").append(OrderReviewItem(cartItem));
    $("#summary-subtotal, #summary-total, #btn-pay-total").text(formattedTotal);

    createIcons({ icons });
  </script>
{% endblock %}
