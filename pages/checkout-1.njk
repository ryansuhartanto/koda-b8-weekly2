{% extends "../layouts/main.njk" %}
{% from "../components/checkout.njk" import stepper, summary %}

{% block main %}
  <main class="pt-6 pb-16 bg-gray-50">
    <div class="wrapper flex flex-col gap-12">
      {{ stepper(1) }}

      <div class="grid grid-cols-3 gap-8 items-start">
        <section
          aria-label="Shipping details"
          class="col-span-2 flex flex-col gap-6 bg-white border border-black/10 rounded-2xl p-6"
        >
          <h2 class="flex items-center gap-2 text-lg font-medium text-gray-900">
            <i data-lucide="truck" class="text-blue-600"></i> Alamat Pengiriman
          </h2>

          <form class="flex flex-col gap-6">
            <div class="flex flex-col gap-4">
              <div class="grid grid-cols-2 gap-4">
                <label class="flex flex-col gap-2 text-sm text-gray-600">
                  <span
                    class="after:content-['*'] after:ml-1 after:text-red-500"
                    >Nama Penerima</span
                  >
                  <input
                    type="text"
                    value="Budi Santoso"
                    required
                    class="border border-black/10 rounded-xl px-4 py-2.5 outline-none focus:border-blue-600 transition-colors bg-gray-50 focus:bg-white text-gray-900"
                  />
                </label>
                <label class="flex flex-col gap-2 text-sm text-gray-600">
                  <span
                    class="after:content-['*'] after:ml-1 after:text-red-500"
                    >Nomor Telepon</span
                  >
                  <input
                    type="tel"
                    value="0812-3456-7890"
                    required
                    class="border border-black/10 rounded-xl px-4 py-2.5 outline-none focus:border-blue-600 transition-colors bg-gray-50 focus:bg-white text-gray-900"
                  />
                </label>
              </div>

              <label class="flex flex-col gap-2 text-sm text-gray-600">
                <span class="after:content-['*'] after:ml-1 after:text-red-500"
                  >Email</span
                >
                <input
                  type="email"
                  value="budi@email.com"
                  required
                  class="border border-black/10 rounded-xl px-4 py-2.5 outline-none focus:border-blue-600 transition-colors bg-gray-50 focus:bg-white text-gray-900"
                />
              </label>

              <label class="flex flex-col gap-2 text-sm text-gray-600">
                <span class="after:content-['*'] after:ml-1 after:text-red-500"
                  >Alamat Lengkap</span
                >
                <input
                  type="text"
                  value="Jl. Kebon Jeruk No. 15"
                  required
                  class="border border-black/10 rounded-xl px-4 py-2.5 outline-none focus:border-blue-600 transition-colors bg-gray-50 focus:bg-white text-gray-900"
                />
              </label>

              <div class="grid grid-cols-2 gap-4">
                <label class="flex flex-col gap-2 text-sm text-gray-600">
                  <span
                    class="after:content-['*'] after:ml-1 after:text-red-500"
                    >Kota</span
                  >
                  <input
                    type="text"
                    value="Jakarta Barat"
                    required
                    class="border border-black/10 rounded-xl px-4 py-2.5 outline-none focus:border-blue-600 transition-colors bg-gray-50 focus:bg-white text-gray-900"
                  />
                </label>
                <label class="flex flex-col gap-2 text-sm text-gray-600">
                  <span
                    class="after:content-['*'] after:ml-1 after:text-red-500"
                    >Provinsi</span
                  >
                  <input
                    type="text"
                    value="DKI Jakarta"
                    required
                    class="border border-black/10 rounded-xl px-4 py-2.5 outline-none focus:border-blue-600 transition-colors bg-gray-50 focus:bg-white text-gray-900"
                  />
                </label>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <label class="flex flex-col gap-2 text-sm text-gray-600">
                  <span
                    class="after:content-['*'] after:ml-1 after:text-red-500"
                    >Kode Pos</span
                  >
                  <input
                    type="text"
                    value="11530"
                    required
                    class="border border-black/10 rounded-xl px-4 py-2.5 outline-none focus:border-blue-600 transition-colors bg-gray-50 focus:bg-white text-gray-900"
                  />
                </label>
                <label class="flex flex-col gap-2 text-sm text-gray-600">
                  <span>Catatan (opsional)</span>
                  <input
                    type="text"
                    placeholder="Warna pagar, dll."
                    class="border border-black/10 rounded-xl px-4 py-2.5 outline-none focus:border-blue-600 transition-colors bg-gray-50 focus:bg-white text-gray-900"
                  />
                </label>
              </div>
            </div>

            <hr class="border-gray-100" />

            <div class="flex flex-col gap-4">
              <h3 class="text-base font-medium text-gray-900">
                Metode Pengiriman
              </h3>

              <div class="flex flex-col gap-3">
                <label
                  class="flex items-center justify-between p-4 border border-blue-600 bg-blue-50/30 rounded-xl cursor-pointer transition-colors"
                >
                  <div class="flex items-center gap-3">
                    <input
                      type="radio"
                      name="shipping"
                      checked
                      class="size-4 accent-blue-600"
                    />
                    <div class="flex flex-col">
                      <span class="text-sm font-medium text-gray-900"
                        >JNE Reguler</span
                      >
                      <span class="text-xs text-gray-500">3-5 hari kerja</span>
                    </div>
                  </div>
                  <span class="text-sm font-medium text-green-600">GRATIS</span>
                </label>

                <label
                  class="flex items-center justify-between p-4 border border-black/10 hover:border-blue-600 rounded-xl cursor-pointer transition-colors"
                >
                  <div class="flex items-center gap-3">
                    <input
                      type="radio"
                      name="shipping"
                      class="size-4 accent-blue-600"
                    />
                    <div class="flex flex-col">
                      <span class="text-sm font-medium text-gray-900"
                        >JNE Express</span
                      >
                      <span class="text-xs text-gray-500">1-2 hari kerja</span>
                    </div>
                  </div>
                  <span class="text-sm font-medium text-green-600">GRATIS</span>
                </label>

                <label
                  class="flex items-center justify-between p-4 border border-black/10 hover:border-blue-600 rounded-xl cursor-pointer transition-colors"
                >
                  <div class="flex items-center gap-3">
                    <input
                      type="radio"
                      name="shipping"
                      class="size-4 accent-blue-600"
                    />
                    <div class="flex flex-col">
                      <span class="text-sm font-medium text-gray-900"
                        >Same Day Delivery</span
                      >
                      <span class="text-xs text-gray-500"
                        >Hari ini (sebelum 16:00)</span
                      >
                    </div>
                  </div>
                  <span class="text-sm font-medium text-green-600">GRATIS</span>
                </label>
              </div>
            </div>

            <button
              type="button"
              class="w-full bg-blue-600 text-white py-3 rounded-xl hover:bg-blue-700 font-medium cursor-pointer transition-colors"
            >
              Lanjut ke Pembayaran &gt;
            </button>
          </form>
        </section>

        {{ summary() }}
      </div>
    </div>
  </main>
{% endblock %}

{% block script %}
  <script type="module">
    import $ from "jquery";
    import { createIcons, icons } from "lucide";
    import { SummaryItem } from "./scripts/components.js";
    import data from "./data.json" with { type: "json" };

    await $.ready;

    const cartItem = { ...data.products[0], quantity: 1 };
    const formattedTotal = `Rp ${(cartItem.price * cartItem.quantity).toLocaleString("id-ID")}`;

    $("#summary-items").append(SummaryItem(cartItem));
    $("#summary-subtotal, #summary-total").text(formattedTotal);

    createIcons({ icons });
  </script>
{% endblock %}
